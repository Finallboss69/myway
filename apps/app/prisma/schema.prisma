generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Zone {
  id     String  @id @default(cuid())
  name   String
  order  Int     @default(0)
  tables Table[]
}

model Table {
  id     String  @id @default(cuid())
  number Int
  zoneId String
  zone   Zone    @relation(fields: [zoneId], references: [id])
  type   String  @default("bar")
  status String  @default("available")
  seats  Int     @default(4)
  x      Float   @default(0)
  y      Float   @default(0)
  w      Float   @default(90)
  h      Float   @default(60)
  orders Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  icon     String    @default("🍺")
  order    Int       @default(0)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  target      String   @default("bar")
  isAvailable Boolean  @default(true)
  isPoolChip  Boolean  @default(false)
}

model Staff {
  id     String @id @default(cuid())
  name   String
  role   String
  avatar String @default("")
  pin    String @default("0000")
}

model Order {
  id            String      @id @default(cuid())
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  tableNumber   Int
  zoneId        String
  status        String      @default("pending")
  waiterName    String?
  paymentMethod String?
  createdAt     DateTime    @default(now())
  closedAt      DateTime?
  items         OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  qty       Int
  price     Float
  status    String @default("pending")
  target    String
  notes     String?
}

model DeliveryOrder {
  id                  String              @id @default(cuid())
  customerName        String
  address             String
  phone               String?
  total               Float
  status              String              @default("pending")
  paymentMethod       String              @default("cash")
  notes               String?
  createdAt           DateTime            @default(now())
  repartidorLat       Float?
  repartidorLng       Float?
  repartidorUpdatedAt DateTime?
  items               DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  name            String
  qty             Int
  price           Float
}

model Ingredient {
  id             String @id @default(cuid())
  name           String
  unit           String
  stockCurrent   Float
  alertThreshold Float
  costPerUnit    Float
}

// ─── Accounting Module ───────────────────────────────────────

model Supplier {
  id        String            @id @default(cuid())
  name      String
  cuit      String?
  address   String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime          @default(now())
  invoices  SupplierInvoice[]
  expenses  Expense[]
}

model SupplierInvoice {
  id            String              @id @default(cuid())
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  number        String
  date          DateTime
  dueDate       DateTime?
  subtotal      Float
  iva           Float               @default(0)
  iibb          Float               @default(0)
  otherTaxes    Float               @default(0)
  total         Float
  photoUrl      String?
  status        String              @default("pending")
  paidAt        DateTime?
  paymentMethod String?
  notes         String?
  createdAt     DateTime            @default(now())
  items         SupplierInvoiceItem[]
  expense       Expense?
}

model SupplierInvoiceItem {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  ivaRate     Float           @default(21)
  subtotal    Float
}

model AfipConfig {
  id              String   @id @default("singleton")
  cuit            String   @default("")
  razonSocial     String   @default("")
  taxRegime       String   @default("monotributo")
  puntoVenta      Int      @default(1)
  certPem         String?
  keyPem          String?
  environment     String   @default("testing")
  autoInvoiceMP   Boolean  @default(false)
  autoInvoiceCash Boolean  @default(false)
  autoInvoiceCard Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String?
  number        Int
  type          String
  puntoVenta    Int
  cae           String?
  caeExpiry     DateTime?
  customerCuit  String?
  customerName  String?
  subtotal      Float
  iva21         Float    @default(0)
  iva105        Float    @default(0)
  percIIBB      Float    @default(0)
  otherTaxes    Float    @default(0)
  total         Float
  afipResponse  String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  ivaRate     Float   @default(21)
  subtotal    Float
}

model ExpenseCategory {
  id       String    @id @default(cuid())
  name     String
  icon     String    @default("📦")
  order    Int       @default(0)
  expenses Expense[]
}

model Expense {
  id                String           @id @default(cuid())
  categoryId        String
  category          ExpenseCategory  @relation(fields: [categoryId], references: [id])
  supplierId        String?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  supplierInvoiceId String?          @unique
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  description       String
  amount            Float
  date              DateTime
  paymentMethod     String?
  notes             String?
  createdAt         DateTime         @default(now())
}

model CashRegister {
  id             String         @id @default(cuid())
  date           DateTime
  openedAt       DateTime       @default(now())
  closedAt       DateTime?
  openingBalance Float
  closingBalance Float?
  status         String         @default("open")
  movements      CashMovement[]
}

model CashMovement {
  id            String       @id @default(cuid())
  registerId    String
  register      CashRegister @relation(fields: [registerId], references: [id])
  type          String
  amount        Float
  concept       String
  paymentMethod String?
  orderId       String?
  expenseId     String?
  createdAt     DateTime     @default(now())
}
