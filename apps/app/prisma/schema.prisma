generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Zone {
  id     String  @id @default(cuid())
  name   String
  order  Int     @default(0)
  tables Table[]
}

model Table {
  id     String  @id @default(cuid())
  number Int
  zoneId String
  zone   Zone    @relation(fields: [zoneId], references: [id])
  type   String  @default("bar")
  status String  @default("available")
  seats  Int     @default(4)
  x      Float   @default(0)
  y      Float   @default(0)
  w      Float   @default(90)
  h      Float   @default(60)
  orders Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  icon     String    @default("🍺")
  order    Int       @default(0)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  target      String   @default("bar")
  isAvailable Boolean  @default(true)
  isPoolChip  Boolean  @default(false)
}

model Staff {
  id     String @id @default(cuid())
  name   String
  role   String
  avatar String @default("")
  pin    String @default("0000")
}

model Order {
  id            String      @id @default(cuid())
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  tableNumber   Int
  zoneId        String
  status        String      @default("pending")
  waiterName    String?
  paymentMethod String?
  createdAt     DateTime    @default(now())
  closedAt      DateTime?
  items         OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  qty       Int
  price     Float
  status    String @default("pending")
  target    String
  notes     String?
}

model DeliveryOrder {
  id                  String              @id @default(cuid())
  customerName        String
  address             String
  phone               String?
  total               Float
  status              String              @default("pending")
  paymentMethod       String              @default("cash")
  notes               String?
  createdAt           DateTime            @default(now())
  repartidorLat       Float?
  repartidorLng       Float?
  repartidorUpdatedAt DateTime?
  items               DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  name            String
  qty             Int
  price           Float
}

model Ingredient {
  id             String @id @default(cuid())
  name           String
  unit           String
  stockCurrent   Float
  alertThreshold Float
  costPerUnit    Float
}
