generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js v5) ───────────────────────────────────

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  emailVerified  DateTime?
  phone          String?
  address        String?
  role           String          @default("customer")
  createdAt      DateTime        @default(now())
  accounts       Account[]
  sessions       Session[]
  deliveryOrders DeliveryOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Restaurant Core ─────────────────────────────────────────

model Zone {
  id     String  @id @default(cuid())
  name   String
  order  Int     @default(0)
  tables Table[]
}

model Table {
  id     String  @id @default(cuid())
  number Int
  zoneId String
  zone   Zone    @relation(fields: [zoneId], references: [id])
  type   String  @default("bar")
  status String  @default("available")
  seats  Int     @default(4)
  x      Float   @default(0)
  y      Float   @default(0)
  w      Float   @default(90)
  h      Float   @default(60)
  orders Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  icon     String    @default("🍺")
  order    Int       @default(0)
  parentId String?
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id               String             @id @default(cuid())
  name             String
  description      String?
  price            Float
  costPrice        Float              @default(0)
  categoryId       String
  category         Category           @relation(fields: [categoryId], references: [id])
  target           String             @default("bar")
  isAvailable      Boolean            @default(true)
  isPoolChip       Boolean            @default(false)
  image            String?
  recipeIngredients RecipeIngredient[]
}

model Staff {
  id     String @id @default(cuid())
  name   String
  role   String
  avatar String @default("")
  pin    String @default("0000")
}

// ─── Orders ──────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  tableNumber   Int
  zoneId        String
  status        String      @default("pending")
  waiterName    String?
  paymentMethod String?
  createdAt     DateTime    @default(now())
  closedAt      DateTime?
  items         OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  qty       Int
  price     Float
  status    String @default("pending")
  target    String
  notes     String?
}

// ─── Delivery ────────────────────────────────────────────────

model DeliveryOrder {
  id                  String              @id @default(cuid())
  userId              String?
  user                User?               @relation(fields: [userId], references: [id])
  customerName        String
  address             String
  phone               String?
  total               Float
  status              String              @default("pending")
  paymentMethod       String              @default("cash")
  notes               String?
  createdAt           DateTime            @default(now())
  repartidorLat       Float?
  repartidorLng       Float?
  repartidorUpdatedAt DateTime?
  items               DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  name            String
  qty             Int
  price           Float
}

// ─── Inventory & Recipes ─────────────────────────────────────

model IngredientCategory {
  id          String       @id @default(cuid())
  name        String
  icon        String       @default("📦")
  order       Int          @default(0)
  ingredients Ingredient[]
}

model Ingredient {
  id               String              @id @default(cuid())
  name             String
  unit             String
  stockCurrent     Float
  alertThreshold   Float
  costPerUnit      Float
  categoryId       String?
  category         IngredientCategory? @relation(fields: [categoryId], references: [id])
  supplierId       String?
  supplier         Supplier?           @relation(fields: [supplierId], references: [id])
  recipeIngredients RecipeIngredient[]
  priceHistory     PriceHistory[]
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String
}

model PriceHistory {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  costPerUnit  Float
  supplierId   String?
  date         DateTime   @default(now())
  notes        String?
}

// ─── Suppliers & Procurement ─────────────────────────────────

model SupplierCategory {
  id        String     @id @default(cuid())
  name      String
  icon      String     @default("📦")
  order     Int        @default(0)
  suppliers Supplier[]
}

model Supplier {
  id          String            @id @default(cuid())
  name        String
  cuit        String?
  address     String?
  phone       String?
  email       String?
  notes       String?
  categoryId  String?
  category    SupplierCategory? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime          @default(now())
  invoices    SupplierInvoice[]
  expenses    Expense[]
  ingredients Ingredient[]
}

model SupplierInvoice {
  id            String              @id @default(cuid())
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  number        String
  date          DateTime
  dueDate       DateTime?
  subtotal      Float
  iva           Float               @default(0)
  iibb          Float               @default(0)
  otherTaxes    Float               @default(0)
  total         Float
  photoUrl      String?
  status        String              @default("pending")
  paidAt        DateTime?
  paymentMethod String?
  notes         String?
  createdAt     DateTime            @default(now())
  items         SupplierInvoiceItem[]
  expense       Expense?
}

model SupplierInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  ivaRate     Float           @default(21)
  subtotal    Float
}

// ─── AFIP & Invoicing ────────────────────────────────────────

model AfipConfig {
  id              String   @id @default("singleton")
  cuit            String   @default("")
  razonSocial     String   @default("")
  taxRegime       String   @default("monotributo")
  puntoVenta      Int      @default(1)
  certPem         String?
  keyPem          String?
  environment     String   @default("testing")
  autoInvoiceMP   Boolean  @default(false)
  autoInvoiceCash Boolean  @default(false)
  autoInvoiceCard Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String?
  number        Int
  type          String
  puntoVenta    Int
  cae           String?
  caeExpiry     DateTime?
  customerCuit  String?
  customerName  String?
  subtotal      Float
  iva21         Float    @default(0)
  iva105        Float    @default(0)
  percIIBB      Float    @default(0)
  otherTaxes    Float    @default(0)
  total         Float
  afipResponse  String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  ivaRate     Float   @default(21)
  subtotal    Float
}

// ─── Expenses & Budgets ──────────────────────────────────────

model ExpenseCategory {
  id             String             @id @default(cuid())
  name           String
  icon           String             @default("📦")
  order          Int                @default(0)
  parentId       String?
  parent         ExpenseCategory?   @relation("ExpenseCategoryTree", fields: [parentId], references: [id])
  children       ExpenseCategory[]  @relation("ExpenseCategoryTree")
  expenses       Expense[]
  budgetMonthly  Float?
}

model Expense {
  id                String           @id @default(cuid())
  categoryId        String
  category          ExpenseCategory  @relation(fields: [categoryId], references: [id])
  supplierId        String?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  supplierInvoiceId String?          @unique
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  description       String
  amount            Float
  date              DateTime
  paymentMethod     String?
  notes             String?
  isRecurring       Boolean          @default(false)
  recurringDay      Int?
  createdAt         DateTime         @default(now())
}

// ─── Cash Register ───────────────────────────────────────────

model CashRegister {
  id             String         @id @default(cuid())
  date           DateTime
  openedAt       DateTime       @default(now())
  closedAt       DateTime?
  openingBalance Float
  closingBalance Float?
  status         String         @default("open")
  movements      CashMovement[]
}

model CashMovement {
  id            String       @id @default(cuid())
  registerId    String
  register      CashRegister @relation(fields: [registerId], references: [id])
  type          String
  amount        Float
  concept       String
  paymentMethod String?
  orderId       String?
  expenseId     String?
  createdAt     DateTime     @default(now())
}

// ─── Daily Reports ───────────────────────────────────────────

model DailyReport {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalRevenue    Float    @default(0)
  totalCost       Float    @default(0)
  totalExpenses   Float    @default(0)
  grossProfit     Float    @default(0)
  netProfit       Float    @default(0)
  ordersCount     Int      @default(0)
  deliveryCount   Int      @default(0)
  avgTicket       Float    @default(0)
  topProducts     String?
  paymentBreakdown String?
  notes           String?
  createdAt       DateTime @default(now())
}
